# ================================================================
# UPS CERT PLATFORM — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets to git.
# ================================================================

# ----------------------------------------------------------------
# Firebase — Client-side (safe to expose in browser)
# ----------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----------------------------------------------------------------
# Firebase Admin SDK — Server-side only (NEVER expose to browser)
# Get from Firebase Console > Project Settings > Service Accounts
# ----------------------------------------------------------------
FIREBASE_CLIENT_EMAIL=
# Paste the private key including -----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----
# In .env.local use: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ----------------------------------------------------------------
# Stripe — Server-side only
# ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Publishable Key — safe to expose in browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — create these in your Stripe Dashboard
# Product: Junior UPS Field Service Certification Exam ($200)
STRIPE_PRICE_ID_JR_FSC=price_...

# Product: UPS Field Service Certification Exam / Proctored ($500)
STRIPE_PRICE_ID_FSC=price_...

# ----------------------------------------------------------------
# Site URL — Used for Stripe success/cancel redirects
# ----------------------------------------------------------------
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Netlify):
# NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# ----------------------------------------------------------------
# Admin emails — comma-separated list of admin email addresses
# These users will have admin role access
# ----------------------------------------------------------------
ADMIN_EMAILS=your-admin-email@example.com

# ----------------------------------------------------------------
# IP Hash Secret — used to HMAC-hash IP addresses for storage
# Generate a strong random string (32+ chars)
# ----------------------------------------------------------------
IP_HASH_SECRET=generate-a-strong-random-secret-here

# ----------------------------------------------------------------
# Seed endpoint secret — protects /api/admin/seed-questions
# Generate a strong random string. Leave blank to disable the endpoint.
# ----------------------------------------------------------------
SEED_SECRET=generate-a-strong-random-secret-here
