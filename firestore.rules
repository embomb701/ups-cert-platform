rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isProctor() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'proctor' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ---------------------------------------------------------------
    // Users
    // ---------------------------------------------------------------
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      // Admins can read all users
      allow read: if isAdmin();
      // Users can only update non-sensitive fields of their own profile
      allow update: if isOwner(userId) &&
        !('role' in request.resource.data) &&
        !('adminNotes' in request.resource.data) &&
        !('blockedReason' in request.resource.data);
      // Client-side creation is handled in the auth flow, but a client must
      // NEVER be able to assert a privileged role or admin-only fields on
      // first write (otherwise isAdmin() — which trusts this very document —
      // can be self-granted). Pin role to 'user' and forbid admin fields.
      allow create: if isOwner(userId) &&
        request.resource.data.role == 'user' &&
        !('adminNotes' in request.resource.data) &&
        !('blockedReason' in request.resource.data);
      // Admins can manage all user records (server uses the Admin SDK, which
      // bypasses rules; this grant is for admin tooling via the client SDK).
      allow update, delete: if isAdmin();
    }

    // User exam access subcollection
    match /users/{userId}/examAccess/{productId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only admin SDK (backend) writes access — never client
      allow write: if false;
    }

    // ---------------------------------------------------------------
    // Products (public read)
    // ---------------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Purchases
    // ---------------------------------------------------------------
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      // Purchases created/updated only by backend (webhook)
      allow write: if false;
    }

    // ---------------------------------------------------------------
    // Question Bank
    // ---------------------------------------------------------------
    match /questionBank/{questionId} {
      // Users CANNOT read the question bank directly
      // Questions are fetched server-side during exam start
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Exam Attempts
    // ---------------------------------------------------------------
    match /examAttempts/{attemptId} {
      // Users can read their own attempts
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      // Proctors can read ONLY attempts explicitly assigned to them — not every
      // proctored attempt (these docs hold answers, choice order and IP hashes).
      allow read: if isProctor() && resource.data.proctorId == request.auth.uid;
      // Attempts created/scored only by backend
      allow write: if false;
    }

    // ---------------------------------------------------------------
    // IP Exam Locks
    // ---------------------------------------------------------------
    match /ipExamLocks/{lockId} {
      // Admin only
      allow read, write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Certificates
    // ---------------------------------------------------------------
    match /certificates/{certificateId} {
      // Users can read their own certificates
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Admins can read all certificates. NOTE: writes are intentionally
      // backend-only — issuance and revocation go through the Admin SDK /
      // server routes, never the client SDK (Firestore OR-combines allow
      // statements, so a client `write: if isAdmin()` here could not be
      // re-denied below; we simply never grant it).
      allow read: if isAdmin();
      // Public verification reads are served by the backend API (admin SDK),
      // so unauthenticated direct reads stay denied by default.
      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------
    // Proctored Exam Orders
    // ---------------------------------------------------------------
    match /proctoredExamOrders/{orderId} {
      // Users can read their own orders
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Proctors may read ONLY orders assigned to them (PII + session unlock
      // state). They never write from the client — unlock goes through the
      // admin-gated /api/admin/proctor-unlock route on the Admin SDK.
      allow read: if isProctor() && resource.data.proctorId == request.auth.uid;
      // Admins can read/update via client tooling; create stays backend-only.
      allow read, update: if isAdmin();
      // Orders created (webhook) and unlocked (admin route) only by backend.
      allow create, delete: if false;
    }

    // ---------------------------------------------------------------
    // Audit Logs
    // ---------------------------------------------------------------
    match /auditLogs/{logId} {
      // Admin only
      allow read, write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Training Modules (future)
    // ---------------------------------------------------------------
    match /trainingModules/{moduleId} {
      allow read: if true; // public read for listing
      allow write: if isAdmin();
    }

  }
}
